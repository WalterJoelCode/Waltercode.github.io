---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

const splitClasses = className.split(" ");
---

<div
  class="rounded-md p-6 w-full border border-gray-300 dark:border-neutral-800 flex flex-col gap-2 bg-white shadow-sm dark:bg-gray-950/30 transition-all duration-300 hover:shadow-lg hover:border-gray-400 dark:hover:border-neutral-700 hover:scale-105"
  class:list={splitClasses}
>
  <slot />
</div>

<style>
  div {
    animation: slideUp 0.6s ease-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
